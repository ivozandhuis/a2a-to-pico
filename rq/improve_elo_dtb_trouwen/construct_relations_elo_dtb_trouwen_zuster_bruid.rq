PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX picom: <https://personsincontext.org/model#>
PREFIX sdo: <https://schema.org/>
PREFIX picot_roles: <https://terms.personsincontext.org/roles/>

CONSTRUCT {
	?bride sdo:sibling ?witness .
    ?witness sdo:gender sdo:Female .
}
WHERE {
    ?witness a picom:PersonObservation ;
    	prov:hadPrimarySource ?src ;
    	sdo:description ?desc .
    FILTER(CONTAINS(?desc, "relatie tot de bruid: zuster"))
    ?bride a picom:PersonObservation ; 
    	prov:hadPrimarySource ?src ;
    	picom:hasRole picot_roles:574 ;
    	sdo:gender sdo:Female .
}